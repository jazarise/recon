{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "ReconX Plugin Metadata Schema",
    "type": "object",
    "required": ["name", "category", "execution_type", "entrypoint", "wrapper"],
    "properties": {
        "name": {
            "type": "string"
        },
        "category": {
            "type": "string"
        },
        "language": {
            "type": "string"
        },
        "execution_type": {
            "type": "string",
            "enum": ["cli", "api", "daemon", "library"]
        },
        "entrypoint": {
            "type": "string"
        },
        "wrapper": {
            "type": "string",
            "default": "adapter.py"
        },
        "input_type": {
            "type": "array",
            "items": { "type": "string" }
        },
        "output_type": {
            "type": "array",
            "items": { "type": "string" }
        },
        "dependencies": {
            "type": "array",
            "items": { "type": "string" }
        },
        "supports_parallel": {
            "type": "boolean"
        },
        "supports_distributed": {
            "type": "boolean"
        },
        "risk_level": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
        }
    }
}
