# portwave — configuration template
# Copy to ~/.config/portwave/config.env and edit as needed.
# The installer (install.sh) will create this automatically after prompting.
#
# All keys are optional. Precedence: CLI flag > environment variable > this file > built-in default.

# Default output root. Each scan writes to <OUTPUT_DIR>/<folder_name>/.
# Example: /home/youruser/scans
PORTWAVE_OUTPUT_DIR=

# Comma-separated (or whitespace-separated) port list.
# Leave blank to use the bundled ports/portwave-top-ports.txt (427 common ports).
# Example: /usr/local/share/portwave/ports/portwave-top-ports.txt
PORTWAVE_PORTS=

# Full path to httpx / nuclei binaries, if not on $PATH.
PORTWAVE_HTTPX_BIN=
PORTWAVE_NUCLEI_BIN=
