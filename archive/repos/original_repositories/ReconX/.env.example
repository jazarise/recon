# ReconX Environment Configuration
# Copy this file to .env and fill in your API keys.
# All keys are optional — ReconX works without any of them.

# AI Analysis (enables OpenAI-powered risk analysis; falls back to rule-based if absent)
OPENAI_API_KEY=

# OSINT enrichment (optional)
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
GITHUB_TOKEN=
